generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Todo {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  imageUrl    String?   // 图片路径
  completed   Boolean   @default(false)
  priority    Int       @default(2)
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
